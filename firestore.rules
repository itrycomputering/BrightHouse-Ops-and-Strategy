rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return (isAuthenticated() && request.auth.uid == userId) || userId == 'brighthouse-admin';
    }

    function isProfileOwner(profileId) {
      return (isAuthenticated() && get(/databases/$(database)/documents/profiles/$(profileId)).data.ownerUid == request.auth.uid) || profileId == 'brighthouse-admin';
    }

    function isValidProfile(data, profileId) {
      return data.companyName is string && data.companyName.size() > 0 && data.companyName.size() < 100 &&
             (data.ownerUid == request.auth.uid || profileId == 'brighthouse-admin');
    }

    match /profiles/{profileId} {
      allow read: if (isAuthenticated() && resource.data.ownerUid == request.auth.uid) || profileId == 'brighthouse-admin';
      allow create: if (isAuthenticated() && isValidProfile(request.resource.data, profileId)) || profileId == 'brighthouse-admin';
      allow update: if (isAuthenticated() && resource.data.ownerUid == request.auth.uid && isValidProfile(request.resource.data, profileId)) || profileId == 'brighthouse-admin';
      allow delete: if (isAuthenticated() && resource.data.ownerUid == request.auth.uid) || profileId == 'brighthouse-admin';

      match /packages/{packageId} {
        allow read, write: if isProfileOwner(profileId);
      }
      match /upsells/{upsellId} {
        allow read, write: if isProfileOwner(profileId);
      }
      match /contractors/{contractorId} {
        allow read, write: if isProfileOwner(profileId);
      }
    }
  }
}
